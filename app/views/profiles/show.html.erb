
<!-- 🎨 CABEÇALHO DO PERFIL (sem Active Storage por enquanto) -->
<div class="relative w-full h-64 bg-gradient-to-r from-blue-900 to-blue-600 rounded-b-2xl overflow-hidden">
  <!-- Botão para editar capa -->
  <% if @is_owner %>
    <div class="absolute top-4 right-4 z-10">
      <button class="bg-black bg-opacity-50 hover:bg-opacity-80 text-white text-sm px-3 py-1 rounded flex items-center gap-1">
        <i class="fas fa-pencil-alt"></i>
        Editar capa
      </button>
    </div>
  <% end %>

  <!-- Foto de perfil (sem imagem por enquanto) -->
  <div class="absolute left-6 -bottom-12 z-20">
    <div class="relative">
      <div class="w-24 h-24 rounded-full bg-white border-4 border-white shadow-lg flex items-center justify-center text-gray-400 text-4xl font-bold">
        <%= @user.nome[0] %>
      </div>

      <% if @is_owner %>
        <button class="absolute bottom-0 right-0 bg-blue-600 text-white p-1 rounded-full hover:bg-blue-700">
          <i class="fas fa-pencil-alt text-xs"></i>
        </button>
      <% end %>
    </div>
  </div>
</div>

<!-- Compensação visual -->
<div class="h-16"></div>

# ----------------------------------------
<h1 class="text-3xl font-bold mb-6 text-blue-500">Perfil do Músico</h1>

  <p><strong>Nome:</strong> <%= @user.nome %></p>
  <p><strong>Email:</strong> <%= @user.email %></p>
  <p><strong>Localização:</strong> <%= @user.localizacao %></p>
  
  <!-- 🎧 Gêneros Musicais -->
  <h2 class="text-xl font-semibold mt-6">Gêneros Musicais</h2>
  
  <div data-controller="genres" data-genres-target="list">
    <%= render partial: "users/genres", locals: { user: @user } %>
  </div>
  
  <% if @is_owner %>
    <h3 class="mt-4 font-semibold">Adicionar/Remover Gêneros:</h3>
    <ul class="space-y-2">
      <% MusicGenre.all.each do |genre| %>
        <li>
          <% if @user.music_genres.include?(genre) %>
            <button
              data-action="click->genres#toggle"
              data-url="<%= remove_from_user_music_genre_path(genre) %>"
              data-method="DELETE"
              class="text-red-500 hover:underline">
              Remover: <%= genre.nome %>
            </button>
          <% else %>
            <button
              data-action="click->genres#toggle"
              data-url="<%= add_to_user_music_genre_path(genre) %>"
              data-method="POST"
              class="text-green-600 hover:underline">
              Adicionar: <%= genre.nome %>
            </button>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>
  
  <!-- ✏️ Biografia -->
  <h2 class="text-xl font-semibold mt-8">Biografia</h2>
  
  <div data-controller="bio">
    <div data-bio-target="display">
      <p><%= @user.bio %></p>
      <% if @is_owner %>
        <button type="button"
                data-action="click->bio#edit"
                class="text-blue-600 hover:underline text-sm">
          Editar
        </button>
      <% end %>
    </div>
  
    <form action="<%= update_bio_user_path(@user) %>" method="post" data-action="submit->bio#update" data-bio-target="form" class="hidden">
      <input type="hidden" name="_method" value="patch" />
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  
      <textarea name="user[bio]" class="w-full border p-2 mt-2 text-sm"><%= @user.bio %></textarea>
  
      <div class="mt-2 flex gap-2">
        <button type="submit" class="px-3 py-1 bg-green-500 text-white text-sm rounded">Salvar</button>
        <button type="button" class="px-3 py-1 bg-gray-300 text-sm rounded" data-action="click->bio#cancel">Cancelar</button>
      </div>
    </form>
  </div>
  
  <p class="mt-4"><strong>Status:</strong> <%= @user.status ? "Disponível" : "Indisponível" %></p>
  <p><strong>Avaliação:</strong> <%= @user.avaliacao %></p>
  <p><strong>Telefone:</strong> <%= @user.telefone %></p>
  
  <!-- 💼 Serviços -->
  <hr class="my-6">
  <h2 class="text-xl font-semibold">Serviços</h2>
  <ul class="list-disc list-inside">
    <% @user.service_types.each do |service| %>
      <li><%= service.nome %> - R$ <%= service.preco %></li>
    <% end %>
  </ul>
# -----------------------------------
<div data-controller="services">
  <div data-services-target="list">
    <%= render partial: "users/services", locals: { user: @user } %>
  </div>

  <% if @is_owner %>
    <form data-services-target="form"
          data-action="submit->services#submit"
          class="mt-4 space-y-2">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <input type="hidden" data-services-target="serviceId">

      <input type="text" placeholder="Nome do serviço"
             data-services-target="nome"
             class="border w-full p-2 text-sm rounded" required>

      <input type="number" step="0.01" placeholder="Preço"
             data-services-target="preco"
             class="border w-full p-2 text-sm rounded" required>

      <div class="flex gap-2">
        <button type="submit" class="bg-green-500 text-white px-3 py-1 text-sm rounded">Salvar</button>
        <button type="button" data-action="click->services#cancel" class="text-sm text-gray-500">Cancelar</button>
      </div>
    </form>
  <% end %>
</div>

# ------------------------------
  <!-- 📅 Disponibilidade -->
  <hr class="my-6">
  <h2 class="text-xl font-semibold">Disponibilidade</h2>
  <ul class="list-disc list-inside">
    <% @user.availabilities.each do |a| %>
      <li><%= a.data.strftime("%d/%m/%Y") %>: <%= a.disponivel ? "Disponível" : "Indisponível" %></li>
    <% end %>
  </ul>
  
  <!-- 🎤 SOBRE EDDIE BLUE -->
  <section class="bg-gradient-to-b from-gray-900 to-black text-white py-16 px-8 rounded-xl shadow-lg mt-12">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-6 text-blue-400">🎧 Sobre Eddie Blue</h2>
  
      <p class="text-lg leading-relaxed mb-6">
        Eddie Blue é mais que um baterista. É engenheiro de software, maestro musical e mente inquieta em constante criação.
      </p>
  
      <p class="text-lg leading-relaxed mb-6">
        Como músico profissional, leva sua paixão pelos ritmos para além dos palcos — traduzindo compassos em código e batidas em ideias. Seu trabalho une arte e tecnologia com sensibilidade, precisão e ousadia.
      </p>
  
      <p class="text-lg leading-relaxed mb-6">
        Criador de ferramentas, pacotes e soluções para músicos e desenvolvedores, Eddie transforma ideias em sons, e sonhos em software.
      </p>
  
      <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-gray-800 rounded-2xl p-6 shadow-lg">
          <h3 class="text-2xl font-semibold text-blue-300 mb-2">🎵 Música</h3>
          <p>Mais de 15 anos como baterista, regente e produtor musical. Projetos autorais e colaborações com artistas independentes.</p>
        </div>
  
        <div class="bg-gray-800 rounded-2xl p-6 shadow-lg">
          <h3 class="text-2xl font-semibold text-blue-300 mb-2">💻 Engenharia</h3>
          <p>Engenheiro de Software com foco em Ruby, JavaScript e Inteligência Artificial. Criador de gems e soluções criativas.</p>
        </div>
      </div>
    </div>
  </section>
  