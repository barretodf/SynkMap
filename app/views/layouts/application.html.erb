<!DOCTYPE html>
<html>
  <head>
    <title>SynkMap</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100 text-gray-800">

    <!-- Header -->
    <header class="bg-white shadow mb-6">
      <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
        <h1 class="text-xl font-bold text-blue-600">
          <%= link_to "SynkMap", root_path %>
        </h1>

        <nav class="space-x-4">
          <% if user_signed_in? %>
            <%= link_to "Meu Perfil", profile_path(current_user), class: "text-sm text-gray-700 hover:text-blue-500" %>
            <%= link_to "Sair", destroy_user_session_path, method: :delete, class: "text-sm text-red-600 hover:text-red-800" %>
          <% else %>
            <%= link_to "Entrar", new_user_session_path, class: "text-sm text-gray-700 hover:text-blue-600" %>
            <%= link_to "Cadastrar", new_user_registration_path, class: "text-sm text-green-600 hover:text-green-800" %>
          <% end %>
        </nav>
      </div>
    </header>

    <!-- Conteúdo da página -->
    <main class="max-w-6xl mx-auto px-4">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="text-center text-sm text-gray-500 py-6 mt-10 border-t">
      &copy; <%= Time.current.year %> SynkMap. Todos os direitos reservados.
    </footer>

  </body>
</html>
